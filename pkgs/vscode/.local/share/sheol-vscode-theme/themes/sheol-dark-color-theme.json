    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#4a3a1f",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "string.quoted", "string.template"],
            "settings": {
                "foreground": "#c9a651"
            }
        },
        {
            "scope": ["string.regexp", "constant.character.escape"],
            "settings": {
                "foreground": "#a08240"
            }
        },
        {
            "scope": ["constant.numeric", "constant.language"],
            "settings": {
                "foreground": "#e8c870"
            }
        },
        {
            "scope": ["constant.language.boolean", "constant.language.null"],
            "settings": {
                "foreground": "#a08240",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["keyword", "storage.type", "storage.modifier"],
            "settings": {
                "foreground": "#a08240",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["keyword.control", "keyword.control.flow"],
            "settings": {
                "foreground": "#c9a651",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["keyword.operator"],
            "settings": {
                "foreground": "#6b6470"
            }
        },
        {
            "scope": ["entity.name.function", "support.function", "meta.function-call"],
            "settings": {
                "foreground": "#e8c870"
            }
        },
        {
            "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"],
            "settings": {
                "foreground": "#c9a651",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["variable", "variable.other"],
            "settings": {
                "foreground": "#b8aea0"
            }
        },
        {
            "scope": ["variable.parameter"],
            "settings": {
                "foreground": "#d4c8b0",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["variable.language", "variable.language.this", "variable.language.self"],
            "settings": {
                "foreground": "#e8c870",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["entity.name.tag", "punctuation.definition.tag"],
            "settings": {
                "foreground": "#a08240"
            }
        },
        {
            "scope": ["entity.other.attribute-name"],
            "settings": {
                "foreground": "#c9a651",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["meta.attribute"],
            "settings": {
                "foreground": "#c9a651"
            }
        },
        {
            "scope": ["punctuation"],
            "settings": {
                "foreground": "#6b6470"
            }
        },
        {
            "scope": ["meta.diff.header"],
            "settings": {
                "foreground": "#a08240"
            }
        },
        {
            "scope": ["markup.heading"],
            "settings": {
                "foreground": "#e8c870",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.bold"],
            "settings": {
                "foreground": "#c9a651",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.italic"],
            "settings": {
                "foreground": "#b8aea0",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["markup.underline.link"],
            "settings": {
                "foreground": "#a08240",
                "fontStyle": "underline"
            }
        },
        {
            "scope": ["markup.inserted"],
            "settings": {
                "foreground": "#6b5530"
            }
        },
        {
            "scope": ["markup.deleted"],
            "settings": {
                "foreground": "#5a1a1a"
            }
        },
        {
            "scope": ["markup.changed"],
            "settings": {
                "foreground": "#c9a651"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#5a1a1a",
                "fontStyle": "underline"
            }
        }
    ]
}
